APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Kashier (Payment Sessions)
KASHIER_ENABLED=false
KASHIER_MODE=test
KASHIER_MERCHANT_ID=
KASHIER_API_KEY=
KASHIER_SECRET_KEY=
KASHIER_CURRENCY=EGP
KASHIER_TYPE=external

# Optional: hosted payment UI language (if supported by Kashier), e.g. ar/en
KASHIER_DISPLAY=

# Optional overrides (absolute URLs / route name / /relative). Leave blank to use built-in routes:
# - Callback: {APP_URL}/api/payments/kashier/callback
# - Webhook:  {APP_URL}/api/payments/kashier/webhook
KASHIER_MERCHANT_REDIRECT_URL=
KASHIER_SERVER_WEBHOOK_URL=

# Where the callback result page "Continue" button sends the user (e.g. mobile deep link / website).
KASHIER_CALLBACK_REDIRECT_URL=

# Optional webhook protection token (recommended). If set, Kashier webhooks must call:
#   {serverWebhookUrl}?token=KASHIER_WEBHOOK_TOKEN
KASHIER_WEBHOOK_TOKEN=

KASHIER_MAX_FAILURE_ATTEMPTS=3
KASHIER_SESSION_EXPIRE_MINUTES=30
KASHIER_TIMEOUT=30
KASHIER_LOG_CHANNEL=kashier
KASHIER_WEBHOOK_LOG_CHANNEL=kashier_webhook
